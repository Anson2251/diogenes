{
  "name": "diogenes",
  "version": "0.1.0",
  "description": "A minimal LLM-controlled agent framework with explicit context management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "diogenes": "dist/cli.js"
  },
  "scripts": {
    "build": "pnpm tsgo",
    "dev": "pnpm tsgo --watch",
    "test": "jest",
    "lint": "npx oxlint",
