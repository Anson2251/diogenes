{
  "name": "diogenes",
  "version": "0.1.0-alpha.2",
  "description": "A minimal LLM-controlled agent framework with explicit context management",
  "keywords": [
    "agent",
    "cli",
    "framework",
    "llm"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "diogenes": "dist/cli.js"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "typecheck": "pnpm tsgo --noEmit",
    "fmt": "pnpm oxfmt",
    "build": "pnpm tsgo",
    "dev": "pnpm tsgo --watch",
    "test": "vitest run",
    "lint": "npx oxlint",
    "bundle": "npx rolldown -c rolldown.cli.config.ts --minify",
    "bundle:all": "pnpm build && pnpm bundle"
  },
  "dependencies": {
    "@tron-format/tron": "^0.1.3",
    "@vscode/tree-sitter-wasm": "0.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "rotating-file-stream": "^3.2.9",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.18.1",
    "rolldown": "1.0.0-rc.12",
    "vitest": "^4.1.3"
  }
}
