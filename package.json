{
  "name": "diogenes",
  "version": "0.1.0-alpha.2",
  "description": "A minimal LLM-controlled agent framework with explicit context management",
  "keywords": [
    "agent",
    "cli",
    "framework",
    "llm"
  ],
  "license": "MIT",
  "author": "",
  "bin": {
    "diogenes": "dist/cli.js",
    "diogenes-acp": "dist/acp-cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "typecheck": "pnpm tsgo --noEmit",
    "fmt": "pnpm oxfmt",
    "build": "pnpm tsgo",
    "dev": "pnpm tsgo --watch",
    "test": "vitest run",
    "lint": "npx oxlint",
    "bundle": "pnpm build && npx rolldown dist/cli.js --file bundle/cli.cjs --format cjs --minify",
    "bundle:acp": "pnpm build && npx rolldown dist/acp-cli.js --file bundle/acp-server.cjs --format cjs --minify"
  },
  "dependencies": {
    "@tron-format/tron": "^0.1.3",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.1",
    "dotenv": "^17.3.1",
    "pino": "^10.3.1",
    "rotating-file-stream": "^3.2.9",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "rolldown": "1.0.0-rc.12",
    "vitest": "^4.1.2"
  }
}
